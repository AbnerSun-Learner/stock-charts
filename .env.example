# Required for /view/* access. Use a long random string in production.
SECRET_TOKEN=your-secret-token-here

# Optional: set in Vercel to your production URL (e.g. https://your-app.vercel.app) so Notion/link previews get correct og:image URLs.
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Required when using Supabase for chart data (optional: app falls back to data/position_distribution.json if unset).
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Set to true to always use local data/position_distribution.json instead of Supabase (for local dev with Excel 导出的 JSON).
# USE_LOCAL_CHART_DATA=true
